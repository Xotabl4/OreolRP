@echo off
:: Устанавливаем кастомный порт для разработки (монтируйте любой свободный, например 8080 или 3000)
set PORT=25565

echo ==============================================
echo Запуск локального сервера OreolSite
echo Порт: %PORT%
echo Доступ в локальной сети будет открыт (флаг --host)
echo ==============================================
echo.
echo Чтобы остановить сервер, нажмите Ctrl+C в этом окне.
echo.

:: Запускаем npm run dev передавая флаги: 
:: --host (сделает сайт доступным с других устройств в вашей WiFi сети)
:: --port (установит заданный выше порт)
call npm run dev -- --host --port %PORT%

pause
